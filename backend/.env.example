# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=cursus
MONGODB_DOCUMENTS_COLLECTION=rag_documents
MONGODB_QUESTIONS_COLLECTION=qpaper_questions

# Pinecone
PINECONE_API_KEY=<your-pinecone-api-key>
PINECONE_INDEX_NAME=<your-pinecone-index-name>
PINECONE_EMBEDDING_MODEL=llama-text-embed-v2
PINECONE_BATCH_SIZE=50
PINECONE_NOTES_NAMESPACE=notes
PINECONE_QPAPER_NAMESPACE=qpaper

# Gemini
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-3-flash-preview

# Ingestion + chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
REQUEST_TIMEOUT_SECONDS=45
CLEAN_QUERY_MIN_SCORE=0.2
